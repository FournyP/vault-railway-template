{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(docker build *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git log *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": ["Bash(rm -rf *)", "Bash(curl *)"]
  }
}
